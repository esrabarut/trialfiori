<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    controllerName="com.trial.trialprojectwithnorthwind.controller.Home"
>
    <Shell>
        <App>
            <pages>
                <Page title="{i18n>homePageTitle}">
                    <content>
                        <Panel
                            xmlns="sap.m"
                            width="auto"
                            expandable="true"
                            expanded="true"
                            id="panel1"
                            class="sapUiResponsiveMargin"
                        >
                            <headerToolbar>
                                <Toolbar id="toolbar2">
                                    <Title text="Header" />
                                    <ToolbarSpacer />
                                    <Button icon="sap-icon://settings" />
                                </Toolbar>
                            </headerToolbar>
                            <content>
                                <Text
                                    text="Panel Content"
                                    id="text4"
                                />
                                <VBox
                                    width="100%"
                                    direction="Column"
                                    id="vbox1"
                                >
                                    <items>
                                        <Panel
                                            xmlns="sap.m"
                                            headerText="{i18n>helloPanelTitle}"
                                            class="sapUiResponsiveMargin"
                                            width="auto"
                                        >
                                            <content>
                                                <VBox
                                                    width="100%"
                                                    direction="Column"
                                                    id="vbox2"
                                                    class="sapUiResponsiveMargin"
                                                >
                                                    <items>
                                                        <Input
                                                            xmlns="sap.m"
                                                            value="{homeModel>/recipient/name}"
                                                            description="Hello {homeModel>/recipient/name}"
                                                            valueLiveUpdate="true"
                                                            width="60%"
                                                            textAlign="Center"
                                                            textDirection="LTR"
                                                        />
                                                        <Button
                                                            xmlns="sap.m"
                                                            text="{i18n>showHelloButtonText}"
                                                            press=".onShowHello"
                                                        />
                                                        <Button
                                                            xmlns="sap.m"
                                                            text="NAVIGATE"
                                                            press=".onNavigate"
                                                            textDirection="LTR"
                                                        />
                                                    </items>
                                                </VBox>
                                            </content>
                                        </Panel>
                                    </items>
                                </VBox>
                            </content>
                        </Panel>
                    </content>
                </Page>
            </pages>
        </App>
    </Shell>
</mvc:View>
